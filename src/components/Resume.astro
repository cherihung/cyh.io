---
import Education from '../data/ed';
import Experience from '../data/exp';
---

<div class="resume">
  <div class="section">
    <h4>Skills</h4>
    <p><strong>Leadership:</strong> Organizational Leadership, Organizational Efficiency, Technical Strategy, Team Building, Agile Development</p>
    <p><strong>AI/ML:</strong> Amazon Bedrock, Amazon SageMaker, LLMs &amp; Agentic Workflows (MCP), RAG, ML Pipelines, AI-assisted SDLC</p>
    <p><strong>Architecture:</strong> Distributed Systems, Event-Driven Architecture (Kafka), Data Engineering, Scalability</p>
    <p><strong>Languages &amp; Frameworks:</strong> JavaScript/TypeScript, Python, React, Node.js, GraphQL</p>
    <p><strong>Platforms &amp; Data:</strong> AWS, Docker, Cassandra, SQL, ElasticSearch/OpenSearch</p>
  </div>
  <div class="section">
    <h4>Related Experience</h4>
    {Experience.map((item) => (
      <div>
        <h3>{item.company} &mdash; <i>{item.title}</i></h3>
        <span>{item.dates} | {item.location}</span>
        <p>{item.description}</p>
      </div>
    ))}
  </div>
  <div class="section">
    <h4>Education</h4>
    {Education.map((item) => (
      <div>
        <h3>{item.school} &mdash; <i>{item.degree}</i></h3>
        <span>{item.dates} | {item.location}</span>
        <p>{item.description}</p>
      </div>
    ))}
  </div>
</div>
